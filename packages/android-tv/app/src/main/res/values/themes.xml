<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ReelTV" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@color/reel_background</item>
        <item name="android:colorBackground">@color/reel_background</item>
        <item name="colorPrimary">@color/reel_primary</item>
        <item name="colorAccent">@color/reel_primary</item>
        <item name="android:textColor">@color/reel_text</item>
        <item name="android:textColorPrimary">@color/reel_text</item>
        <item name="android:textColorSecondary">@color/reel_text_muted</item>
    </style>

    <style name="Theme.ReelTV.Fullscreen" parent="Theme.ReelTV">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>
</resources>
